import csv
import os
from datetime import datetime
from arquivos import carregar_dados
from auxiliares import ler_data

def salvar_relatorio(dados, colunas, nome_base, usuario):
    """Salva um relatório com nome do usuário e data/hora."""
    formato = input("Deseja salvar como (1) .txt ou (2) .csv? ").strip()
    nome_arquivo = f"{nome_base}_{usuario}_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
    os.makedirs("relatorios", exist_ok=True)

    if formato == '1':
        caminho = os.path.join("relatorios", f"{nome_arquivo}.txt")
        with open(caminho, 'w', encoding='utf-8') as f:
            largura = 30
            f.write("".join(f"{c:<{largura}}" for c in colunas) + "\n")
            f.write("-" * (largura * len(colunas)) + "\n")
            for linha in dados:
                f.write("".join(f"{str(linha.get(c, '')):<{largura}}" for c in colunas) + "\n")
    elif formato == '2':
        caminho = os.path.join("relatorios", f"{nome_arquivo}.csv")
        with open(caminho, 'w', newline='', encoding='utf-8') as f:
            writer = csv.DictWriter(f, fieldnames=colunas)
            writer.writeheader()
            for linha in dados:
                writer.writerow(linha)
    else:
        print("Formato inválido. Relatório não salvo.")
        return

    print(f"Relatório salvo como: {caminho}")

def relatorio_pacientes_por_periodo(usuario):
    """Gera relatório de pacientes atendidos em um período (com nomes)."""
    pacientes, atendimentos = carregar_dados()
    data_inicio = ler_data("Data inicial (DD/MM/AAAA): ")
    data_fim = ler_data("Data final (DD/MM/AAAA): ")

    relatorio = []
    for at in atendimentos:
        try:
            data_atendimento = datetime.strptime(at['Data'], "%d/%m/%Y")
        except (ValueError, KeyError):
            continue

        if data_inicio <= data_atendimento <= data_fim:
            cartao = at['CartaoSUS']
            paciente = pacientes.get(cartao, {'Nome': 'Desconhecido', 'Bairro': '', 'Nascimento': ''})
            relatorio.append({
                'Nome': paciente.get('Nome', 'Desconhecido'),
                'CartaoSUS': cartao,
                'DataAtendimento': at.get('Data', ''),
                'Tipo': at.get('Tipo', ''),
                'Usuario': at.get('Usuario', 'Desconhecido'),
                'Registro': at.get('Registro', '')
            })

    relatorio.sort(key=lambda x: datetime.strptime(x['DataAtendimento'], "%d/%m/%Y"), reverse=True)

    if not relatorio:
        print("Nenhum atendimento encontrado no período especificado.")
        return

    for item in relatorio:
        print(f"{item['DataAtendimento']} - {item['Nome']} - Cartão SUS: {item['CartaoSUS']} - Tipo: {item['Tipo']}")

    if input("Deseja salvar o relatório? (s/n): ").lower() == 's':
        salvar_relatorio(relatorio, ['Nome', 'CartaoSUS', 'DataAtendimento', 'Tipo', 'Usuario', 'Registro'],
                         'relatorio_pacientes_periodo', usuario)

def relatorio_tipo_atendimento(usuario):
    """Gera relatório de quantidade por tipo de atendimento."""
    _, atendimentos = carregar_dados()
    contagem = {}
    for at in atendimentos:
        tipo = at.get('Tipo', '')
        contagem[tipo] = contagem.get(tipo, 0) + 1

    relatorio = [{'Tipo': tipo, 'Quantidade': qtd} for tipo, qtd in contagem.items()]
    for item in relatorio:
        print(f"{item['Tipo']}: {item['Quantidade']}")

    if input("Deseja salvar o relatório? (s/n): ").lower() == 's':
        salvar_relatorio(relatorio, ['Tipo', 'Quantidade'], 'relatorio_tipos', usuario)

def relatorio_atendimentos_por_bairro(usuario):
    """Gera relatório de atendimentos por bairro (usa nome do paciente via relação)."""
    pacientes, atendimentos = carregar_dados()
    contagem = {}
    for at in atendimentos:
        paciente = pacientes.get(at.get('CartaoSUS', ''))
        if paciente:
            bairro = paciente.get('Bairro', '')
            contagem[bairro] = contagem.get(bairro, 0) + 1

    relatorio = [{'Bairro': b, 'Atendimentos': qtd} for b, qtd in contagem.items()]
    for item in relatorio:
        print(f"{item['Bairro']}: {item['Atendimentos']}")

    if input("Deseja salvar o relatório? (s/n): ").lower() == 's':
        salvar_relatorio(relatorio, ['Bairro', 'Atendimentos'], 'relatorio_bairros', usuario)

def relatorio_historico_paciente(usuario):
    """Gera histórico de atendimentos de um paciente específico (com nome)."""
    cartao = input("Informe o número do cartão SUS do paciente (15 dígitos): ").strip()
    if not cartao.isdigit() or len(cartao) != 15:
        print("Erro: Cartão SUS inválido.")
        return

    pacientes, atendimentos = carregar_dados()
    paciente = pacientes.get(cartao)
    if not paciente:
        print("Paciente não encontrado.")
        return

    historico = [at for at in atendimentos if at.get('CartaoSUS') == cartao]
    if not historico:
        print("Nenhum atendimento encontrado para este paciente.")
        return

    historico.sort(key=lambda x: datetime.strptime(x['Data'], "%d/%m/%Y"))

    dados_formatados = []
    print(f"\n--- Histórico de atendimentos para {paciente['Nome']} ---")
    for at in historico:
        registro = {
            'Nome': paciente['Nome'],
            'CartaoSUS': paciente['CartaoSUS'],
            'Nascimento': paciente['Nascimento'],
            'Bairro': paciente['Bairro'],
            'Tipo': at.get('Tipo', ''),
            'DataAtendimento': at.get('Data', ''),
            'Usuario': at.get('Usuario', 'Desconhecido'),
            'Registro': at.get('Registro', '')
        }
        dados_formatados.append(registro)
        print(f"{registro['DataAtendimento']} - {registro['Tipo']} - "
              f"{registro['Nome']}, Cartão SUS: {registro['CartaoSUS']}, "
              f"Nasc.: {registro['Nascimento']}, Bairro: {registro['Bairro']}")

    if input("Deseja salvar o relatório? (s/n): ").lower() == 's':
        salvar_relatorio(dados_formatados,
                         ['Nome', 'CartaoSUS', 'Nascimento', 'Bairro', 'Tipo', 'DataAtendimento', 'Usuario', 'Registro'],
                         f"historico_{cartao}", usuario)

def menu_relatorios(usuario):
    """Menu de relatórios."""
    while True:
        print("\n--- RELATÓRIOS ---")
        print("1. Pacientes atendidos em período")
        print("2. Quantidade por tipo de atendimento")
        print("3. Número de atendimentos por bairro")
        print("4. Histórico por paciente")
        print("5. Voltar")
        opcao = input("Escolha uma opção: ")

        if opcao == '1':
            relatorio_pacientes_por_periodo(usuario)
        elif opcao == '2':
            relatorio_tipo_atendimento(usuario)
        elif opcao == '3':
            relatorio_atendimentos_por_bairro(usuario)
        elif opcao == '4':
            relatorio_historico_paciente(usuario)
        elif opcao == '5':
            break
        else:
            print("Opção inválida.")